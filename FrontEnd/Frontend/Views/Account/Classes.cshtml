@{
    Layout = null;
    ViewData["Title"] = "Attendance Manager – Classes";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #c8d9a0;
            --sidebar-bg: #5a7a3a;
            --surface: #d4e4aa;
            --card: #e4f0c0;
            --border: rgba(90,122,58,0.22);
            --accent: #3d6b20;
            --accent-light: #5c8f35;
            --text: #243318;
            --text2: #527038;
            --text3: #7a9858;
            --red: #b83228;
            --red-bg: rgba(184,50,40,0.1);
            --amber: #a86820;
            --amber-bg: rgba(168,104,32,0.1);
            --blue: #2a5f8a;
            --blue-bg: rgba(42,95,138,0.1);
            --radius: 16px;
            --sidebar: 228px
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        body {
            font-family: Outfit,sans-serif;
            background: var(--bg);
            color: var(--text);
            display: flex;
            height: 100vh;
            overflow: hidden
        }

        aside {
            width: var(--sidebar);
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            flex-shrink: 0
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 22px 18px;
            border-bottom: 1px solid rgba(255,255,255,.12)
        }

        .brand-icon {
            width: 38px;
            height: 38px;
            background: rgba(255,255,255,.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center
        }

        .brand-name {
            font-size: 14px;
            font-weight: 700;
            color: #fff;
            line-height: 1.2
        }

        .brand-sub {
            font-size: 10px;
            color: rgba(255,255,255,.5)
        }

        nav {
            flex: 1;
            padding: 14px 10px;
            display: flex;
            flex-direction: column;
            gap: 3px;
            overflow-y: auto
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 9px 12px;
            border-radius: 10px;
            cursor: pointer;
            color: rgba(255,255,255,.6);
            font-size: 13px;
            font-weight: 500;
            transition: all .2s;
            text-decoration: none
        }

            .nav-item:hover {
                background: rgba(255,255,255,.1);
                color: #fff
            }

            .nav-item.active {
                background: rgba(255,255,255,.2);
                color: #fff;
                font-weight: 600
            }

        .nav-icon {
            width: 18px;
            text-align: center;
            font-size: 14px
        }

        .sidebar-footer {
            padding: 14px;
            border-top: 1px solid rgba(255,255,255,.12)
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            background: rgba(255,255,255,.1);
            margin-bottom: 8px
        }

        .avatar {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: rgba(255,255,255,.22);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0
        }

        .user-name {
            font-size: 12.5px;
            font-weight: 600;
            color: #fff
        }

        .user-role {
            font-size: 10px;
            color: rgba(255,255,255,.5)
        }

        .logout-btn {
            width: 100%;
            padding: 8px;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,.15);
            background: transparent;
            color: rgba(255,255,255,.6);
            font-size: 12px;
            font-family: Outfit,sans-serif;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            transition: all .2s
        }

            .logout-btn:hover {
                background: rgba(255,255,255,.1);
                color: #fff
            }

        main {
            flex: 1;
            overflow-y: auto;
            padding: 28px;
            display: flex;
            flex-direction: column;
            gap: 20px
        }

            main::-webkit-scrollbar {
                width: 4px
            }

            main::-webkit-scrollbar-thumb {
                background: var(--surface);
                border-radius: 10px
            }

        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between
        }

        .page-title {
            font-size: 24px;
            font-weight: 800
        }

        .page-sub {
            font-size: 12.5px;
            color: var(--text2);
            margin-top: 3px
        }

        .add-btn {
            padding: 10px 20px;
            border-radius: 10px;
            background: var(--accent);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            font-family: Outfit,sans-serif;
            transition: all .2s
        }

            .add-btn:hover {
                background: var(--accent-light);
                transform: translateY(-1px)
            }

        .kpi-row {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 12px
        }

        .kpi-mini {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 16px 18px
        }

        .kl {
            font-size: 11px;
            font-weight: 600;
            color: var(--text2);
            text-transform: uppercase;
            letter-spacing: .06em;
            margin-bottom: 7px
        }

        .kv {
            font-size: 28px;
            font-weight: 800;
            font-family: monospace
        }

        .ks {
            font-size: 11px;
            color: var(--text3);
            margin-top: 3px
        }

        .controls {
            display: flex;
            gap: 10px
        }

        .search-box {
            flex: 1;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 10px 14px;
            display: flex;
            align-items: center;
            gap: 10px
        }

            .search-box input {
                background: transparent;
                border: none;
                outline: none;
                color: var(--text);
                font-size: 13px;
                flex: 1;
                font-family: Outfit,sans-serif
            }

                .search-box input::placeholder {
                    color: var(--text3)
                }

        .f-sel {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 10px 14px;
            color: var(--text2);
            font-size: 13px;
            font-family: Outfit,sans-serif;
            cursor: pointer;
            outline: none
        }

        .table-panel {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden
        }

        .t-head {
            display: grid;
            grid-template-columns: 60px 1fr 1fr 1fr 90px 140px;
            padding: 11px 18px;
            background: var(--surface);
            border-bottom: 1px solid var(--border)
        }

        .th {
            font-size: 10px;
            font-weight: 700;
            color: var(--text3);
            text-transform: uppercase;
            letter-spacing: .07em
        }

        .t-row {
            display: grid;
            grid-template-columns: 60px 1fr 1fr 1fr 90px 140px;
            padding: 13px 18px;
            border-bottom: 1px solid var(--border);
            align-items: center;
            transition: background .15s
        }

            .t-row:last-child {
                border-bottom: none
            }

            .t-row:hover {
                background: var(--surface)
            }

        .id-mono {
            font-size: 11.5px;
            font-family: monospace;
            color: var(--text3)
        }

        .section-val {
            font-size: 13px;
            font-weight: 800;
            color: var(--accent)
        }

        .year-badge {
            font-size: 10px;
            font-weight: 700;
            padding: 3px 8px;
            border-radius: 6px;
            width: fit-content
        }

        .y1 {
            background: var(--blue-bg);
            color: var(--blue)
        }

        .y2 {
            background: rgba(61,107,32,.12);
            color: var(--accent)
        }

        .y3 {
            background: var(--amber-bg);
            color: var(--amber)
        }

        .y4 {
            background: var(--red-bg);
            color: var(--red)
        }

        .course-chip {
            font-size: 11px;
            font-weight: 600;
            background: var(--blue-bg);
            color: var(--blue);
            padding: 3px 10px;
            border-radius: 6px
        }

        .count-val {
            font-size: 13px;
            font-weight: 700;
            font-family: monospace;
            color: var(--text)
        }

        .row-acts {
            display: flex;
            gap: 6px
        }

        .ra-btn {
            padding: 5px 12px;
            border-radius: 7px;
            border: none;
            cursor: pointer;
            font-size: 11.5px;
            font-weight: 600;
            font-family: Outfit,sans-serif;
            transition: all .15s
        }

        .btn-edit {
            background: var(--surface);
            color: var(--text2);
            border: 1px solid var(--border)
        }

            .btn-edit:hover {
                color: var(--accent);
                border-color: var(--accent)
            }

        .btn-del {
            background: var(--red-bg);
            color: var(--red);
            border: 1px solid rgba(184,50,40,.2)
        }

            .btn-del:hover {
                background: rgba(184,50,40,.18)
            }

        .loading-row {
            padding: 24px 18px;
            text-align: center;
            color: var(--text3);
            font-size: 13px
        }

        .error-row {
            color: var(--red)
        }
        /* Modal */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.5);
            z-index: 1000;
            align-items: center;
            justify-content: center
        }

            .modal-overlay.active {
                display: flex
            }

        .modal {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            width: 460px;
            max-width: calc(100vw - 40px);
            box-shadow: 0 20px 60px rgba(0,0,0,.2)
        }

        .modal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 20px;
            border-bottom: 1px solid var(--border);
            font-size: 15px;
            font-weight: 700
        }

        .modal-close {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 18px;
            color: var(--text3);
            line-height: 1
        }

            .modal-close:hover {
                color: var(--red)
            }

        .modal-body {
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 14px
        }

        .modal-footer {
            padding: 16px 20px;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: 10px
        }

        .field {
            display: flex;
            flex-direction: column;
            gap: 6px
        }

        .field-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px
        }

        .field label {
            font-size: 12px;
            font-weight: 600;
            color: var(--text2)
        }

        .field input, .field select {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 9px;
            padding: 10px 12px;
            font-size: 13px;
            color: var(--text);
            font-family: Outfit,sans-serif;
            outline: none
        }

            .field input:focus, .field select:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(61,107,32,.1)
            }

        .field-hint {
            font-size: 11px;
            color: var(--text3)
        }

        .modal-error {
            background: var(--red-bg);
            color: var(--red);
            border: 1px solid rgba(184,50,40,.2);
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 12.5px
        }

        .btn-cancel {
            padding: 9px 20px;
            border-radius: 9px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text2);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            font-family: Outfit,sans-serif
        }

            .btn-cancel:hover {
                background: var(--surface)
            }

        .btn-save {
            padding: 9px 20px;
            border-radius: 9px;
            border: none;
            background: var(--accent);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            font-family: Outfit,sans-serif
        }

            .btn-save:hover {
                background: var(--accent-light)
            }
    </style>
</head>
<body>
    <aside>
        <div class="brand">
            <div class="brand-icon"><img src="~/images/dbtc-logo.png" alt="DBTC Logo" style="width:28px;height:28px;object-fit:contain;border-radius:6px;" /></div>
            <div><div class="brand-name">Attendance</div><div class="brand-sub">Manager Pro</div></div>
        </div>
        <nav>
            <a class="nav-item" href="/Account/Dashboard"><span class="nav-icon">⊞</span> Dashboard</a>
            <a class="nav-item" href="/Account/Students"><span class="nav-icon">🎓</span> Students</a>
            <a class="nav-item" href="/Account/Teachers"><span class="nav-icon">👨‍🏫</span> Teachers</a>
            <a class="nav-item" href="/Account/Courses"><span class="nav-icon">📚</span> Courses</a>
            <a class="nav-item active" href="/Account/Classes"><span class="nav-icon">🏫</span> Classes</a>
            <a class="nav-item" href="/Account/Enrollment"><span class="nav-icon">📋</span> Enrollment</a>
            <a class="nav-item" href="/Account/Attendance"><span class="nav-icon">✓</span> Attendance</a>
            <a class="nav-item" href="/Account/Reports"><span class="nav-icon">📊</span> Reports</a>
            <a class="nav-item" href="/Account/Settings"><span class="nav-icon">⚙</span> Settings</a>
        </nav>
        <div class="sidebar-footer">
            <div class="user-card">
                <div class="avatar">JG</div>
                <div><div class="user-name">James Gulfan</div><div class="user-role">Administrator</div></div>
            </div>
            <form method="post" action="/Account/Logout">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn">↩ Logout</button>
            </form>
        </div>
    </aside>

    <main>
        <div class="page-header">
            <div>
                <div class="page-title">Class Management</div>
                <div class="page-sub">Manage class sections from <code>GET /api/classes</code></div>
            </div>
            <button class="add-btn" onclick="openModal()">+ Add New Class</button>
        </div>

        <div class="kpi-row">
            <div class="kpi-mini"><div class="kl">Total Classes</div><div class="kv" id="kpi-total" style="color:var(--blue)">—</div><div class="ks">All sections</div></div>
            <div class="kpi-mini"><div class="kl">Total Enrollments</div><div class="kv" id="kpi-enrolled" style="color:var(--accent)">—</div><div class="ks">Across all classes</div></div>
            <div class="kpi-mini"><div class="kl">Courses Used</div><div class="kv" id="kpi-courses" style="color:var(--amber)">—</div><div class="ks">Unique courses assigned</div></div>
        </div>

        <div class="controls">
            <div class="search-box"><span>🔍</span><input type="text" id="search-input" placeholder="Search by section or year level…" oninput="filterClasses()" /></div>
            <select class="f-sel" id="filter-year" onchange="filterClasses()">
                <option value="">All Year Levels</option>
                <option>1st Year</option>
                <option>2nd Year</option>
                <option>3rd Year</option>
                <option>4th Year</option>
            </select>
        </div>

        <div class="table-panel">
            <div class="t-head">
                <span class="th">ID</span>
                <span class="th">Section</span>
                <span class="th">Year Level</span>
                <span class="th">Course</span>
                <span class="th">Enrollments</span>
                <span class="th">Actions</span>
            </div>
            <div id="class-list"><div class="loading-row">Loading…</div></div>
        </div>
    </main>

    <!-- Modal -->
    <div class="modal-overlay" id="modal-overlay">
        <div class="modal">
            <div class="modal-header">
                <span id="modal-title">Add New Class</span>
                <button class="modal-close" onclick="closeModal()">✕</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="edit-id" />
                <div class="field-row">
                    <div class="field">
                        <label>Section</label>
                        <input type="text" id="f-section" placeholder="e.g. 10A" />
                    </div>
                    <div class="field">
                        <label>Year Level</label>
                        <select id="f-yearlevel">
                            <option value="">— Select —</option>
                            <option>1st Year</option>
                            <option>2nd Year</option>
                            <option>3rd Year</option>
                            <option>4th Year</option>
                        </select>
                    </div>
                </div>
                <div class="field">
                    <label>Course</label>
                    <select id="f-courseid"><option value="">— Select a course —</option></select>
                    <span class="field-hint">Loaded from /api/courses</span>
                </div>
                <div id="modal-error" class="modal-error" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeModal()">Cancel</button>
                <button class="btn-save" id="btn-save" onclick="saveClass()">Save Class</button>
            </div>
        </div>
    </div>

    <script>
        const API = 'https://localhost:7152/api/classes';
        let allClasses = [], allCourses = [];

        async function loadData() {
            try {
                const [clRes, coRes] = await Promise.all([fetch(API), fetch('https://localhost:7152/api/courses')]);
                allClasses = await clRes.json();
                allCourses = coRes.ok ? await coRes.json() : [];
                populateCourseSelect();
                renderClasses(allClasses);
                updateKPIs(allClasses);
            } catch (e) {
                document.getElementById('class-list').innerHTML =
                    '<div class="loading-row error-row">Could not load classes. Is the API running?</div>';
            }
        }

        function populateCourseSelect() {
            document.getElementById('f-courseid').innerHTML =
                '<option value="">— Select a course —</option>' +
                allCourses.map(c => `<option value="${c.id}">${c.courseName}</option>`).join('');
        }

        function updateKPIs(data) {
            document.getElementById('kpi-total').textContent = data.length;
            document.getElementById('kpi-enrolled').textContent = data.reduce((s, c) => s + (c.enrollments?.length ?? 0), 0);
            document.getElementById('kpi-courses').textContent = new Set(data.map(c => c.courseId)).size;
        }

        function yearClass(y) {
            return y === '1st Year' ? 'y1' : y === '2nd Year' ? 'y2' : y === '3rd Year' ? 'y3' : 'y4';
        }

        function renderClasses(data) {
            const list = document.getElementById('class-list');
            if (!data.length) { list.innerHTML = '<div class="loading-row">No classes found.</div>'; return; }
            list.innerHTML = data.map(c => {
                const courseName = c.course?.courseName ?? allCourses.find(x => x.id === c.courseId)?.courseName ?? 'Course #' + c.courseId;
                return `<div class="t-row">
                    <span class="id-mono">${c.id}</span>
                    <span class="section-val">${c.section}</span>
                    <span class="year-badge ${yearClass(c.yearLevel)}">${c.yearLevel}</span>
                    <span class="course-chip">${courseName}</span>
                    <span class="count-val">${c.enrollments?.length ?? 0}</span>
                    <div class="row-acts">
                        <button class="ra-btn btn-edit" onclick="openEditModal(${c.id})">✏ Edit</button>
                        <button class="ra-btn btn-del" onclick="deleteClass(${c.id},'${c.section}')">🗑 Delete</button>
                    </div>
                </div>`;
            }).join('');
        }

        function filterClasses() {
            const q = document.getElementById('search-input').value.toLowerCase();
            const yr = document.getElementById('filter-year').value;
            renderClasses(allClasses.filter(c =>
                (c.section.toLowerCase().includes(q) || c.yearLevel.toLowerCase().includes(q)) &&
                (!yr || c.yearLevel === yr)
            ));
        }

        function openModal() {
            document.getElementById('modal-title').textContent = 'Add New Class';
            document.getElementById('edit-id').value = '';
            document.getElementById('f-section').value = '';
            document.getElementById('f-yearlevel').value = '';
            document.getElementById('f-courseid').value = '';
            document.getElementById('btn-save').textContent = 'Save Class';
            document.getElementById('modal-error').style.display = 'none';
            document.getElementById('modal-overlay').classList.add('active');
        }

        function openEditModal(id) {
            const c = allClasses.find(x => x.id === id); if (!c) return;
            document.getElementById('modal-title').textContent = 'Edit Class';
            document.getElementById('edit-id').value = c.id;
            document.getElementById('f-section').value = c.section;
            document.getElementById('f-yearlevel').value = c.yearLevel;
            document.getElementById('f-courseid').value = c.courseId;
            document.getElementById('btn-save').textContent = 'Update Class';
            document.getElementById('modal-error').style.display = 'none';
            document.getElementById('modal-overlay').classList.add('active');
        }

        function closeModal() {
            document.getElementById('modal-overlay').classList.remove('active');
        }

        async function saveClass() {
            const id = document.getElementById('edit-id').value;
            const body = {
                section:   document.getElementById('f-section').value.trim(),
                yearLevel: document.getElementById('f-yearlevel').value,
                courseId:  parseInt(document.getElementById('f-courseid').value)
            };
            if (!body.section || !body.yearLevel || !body.courseId) { showModalError('All fields are required.'); return; }
            try {
                const res = await fetch(id ? `${API}/${id}` : API, {
                    method: id ? 'PUT' : 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                if (!res.ok) throw new Error(await res.text());
                closeModal(); loadData();
            } catch (e) { showModalError('Save failed: ' + e.message); }
        }

        async function deleteClass(id, section) {
            if (!confirm(`Delete class "${section}"? This cannot be undone.`)) return;
            try {
                const res = await fetch(`${API}/${id}`, { method: 'DELETE' });
                if (!res.ok) throw new Error(await res.text());
                loadData();
            } catch (e) { alert('Delete failed: ' + e.message); }
        }

        function showModalError(msg) {
            const el = document.getElementById('modal-error');
            el.textContent = msg; el.style.display = 'block';
        }

        loadData();
    </script>
</body>
</html>
