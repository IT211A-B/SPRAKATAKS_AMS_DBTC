@{
    Layout = null;
    ViewData["Title"] = "Attendance Manager – Courses";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/courses.css" asp-append-version="true" />
</head>
<body>
    <aside>
        <div class="brand">
            <div class="brand-icon"><img src="~/images/dbtc-logo.png" alt="DBTC Logo" style="width:28px;height:28px;object-fit:contain;border-radius:6px;" /></div>
            <div><div class="brand-name">Attendance</div><div class="brand-sub">Manager Pro</div></div>
        </div>
        <nav>
            <a class="nav-item" href="/Account/Dashboard"><span class="nav-icon">⊞</span> Dashboard</a>
            <a class="nav-item" href="/Account/Students"><span class="nav-icon">🎓</span> Students</a>
            <a class="nav-item" href="/Account/Teachers"><span class="nav-icon">👨‍🏫</span> Teachers</a>
            <a class="nav-item active" href="/Account/Courses"><span class="nav-icon">📚</span> Courses</a>
            <a class="nav-item" href="/Account/Classes"><span class="nav-icon">🏫</span> Classes</a>
            <a class="nav-item" href="/Account/Enrollment"><span class="nav-icon">📋</span> Enrollment</a>
            <a class="nav-item" href="/Account/Attendance"><span class="nav-icon">✓</span> Attendance</a>
            <a class="nav-item" href="/Account/Reports"><span class="nav-icon">📊</span> Reports</a>
            <a class="nav-item" href="/Account/Settings"><span class="nav-icon">⚙</span> Settings</a>
        </nav>
        <div class="sidebar-footer">
            <div class="user-card">
                <div class="avatar">JG</div>
                <div><div class="user-name">James Gulfan</div><div class="user-role">Administrator</div></div>
            </div>
            <form action="/Account/Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn">↩ Logout</button>
            </form>
        </div>
    </aside>

    <main>
        <div class="page-header">
            <div>
                <div class="page-title">Course Management</div>
                <div class="page-sub">Manage courses from <code>GET /api/courses</code></div>
            </div>
            <button class="add-btn" onclick="openModal()">+ Add New Course</button>
        </div>

        <!-- KPI row -->
        <div class="kpi-row">
            <div class="kpi-mini"><div class="kl">Total Courses</div><div class="kv" id="kpi-total" style="color:var(--blue)">—</div><div class="ks">All records</div></div>
            <div class="kpi-mini"><div class="kl">Total Students</div><div class="kv" id="kpi-students" style="color:var(--accent)">—</div><div class="ks">Enrolled across courses</div></div>
            <div class="kpi-mini"><div class="kl">Unassigned</div><div class="kv" id="kpi-noteacher" style="color:var(--amber)">—</div><div class="ks">No teacher set</div></div>
        </div>

        <!-- Search -->
        <div class="controls">
            <div class="search-box"><span>🔍</span><input type="text" id="search-input" placeholder="Search by course name…" oninput="filterCourses()" /></div>
        </div>

        <!-- Table -->
        <div class="table-panel">
            <div class="t-head">
                <span class="th">ID</span>
                <span class="th">Course Name</span>
                <span class="th">Teacher</span>
                <span class="th">Students</span>
                <span class="th">Actions</span>
            </div>
            <div id="course-list"><div class="loading-row">Loading…</div></div>
        </div>
    </main>

    <!-- ── Modal ── -->
    <div class="modal-overlay" id="modal-overlay" onclick="closeModal()"></div>
    <div class="modal" id="modal">
        <div class="modal-header">
            <span id="modal-title">Add New Course</span>
            <button class="modal-close" onclick="closeModal()">✕</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="edit-id" />
            <div class="field">
                <label>Course Name</label>
                <input type="text" id="f-coursename" placeholder="e.g. Introduction to Programming" />
            </div>
            <div class="field">
                <label>Teacher</label>
                <select id="f-teacherid">
                    <option value="">— Select a teacher —</option>
                </select>
                <span class="field-hint">Teachers are loaded from <code>/api/teachers</code></span>
            </div>
            <div id="modal-error" class="modal-error" style="display:none"></div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal()">Cancel</button>
            <button class="btn-save" id="btn-save" onclick="saveCourse()">Save Course</button>
        </div>
    </div>

    <script>
        const API = 'https://localhost:7152/api/courses';
        let allCourses  = [];
        let allTeachers = [];

        async function loadData() {
            try {
                const [cRes, tRes] = await Promise.all([fetch(API), fetch('https://localhost:7152/api/teachers')]);
                allCourses  = await cRes.json();
                allTeachers = tRes.ok ? await tRes.json() : [];
                populateTeacherSelect();
                renderCourses(allCourses);
                updateKPIs(allCourses);
            } catch (e) {
                document.getElementById('course-list').innerHTML =
                    '<div class="loading-row error-row">Could not load courses. Is the API running?</div>';
            }
        }

        function populateTeacherSelect() {
            const sel = document.getElementById('f-teacherid');
            sel.innerHTML = '<option value="">— Select a teacher —</option>' +
                allTeachers.map(t =>
                    `<option value="${t.id}">${t.firstName} ${t.lastName}</option>`
                ).join('');
        }

        function updateKPIs(data) {
            document.getElementById('kpi-total').textContent = data.length;
            const totalStudents = data.reduce((sum, c) => sum + (c.students?.length ?? 0), 0);
            document.getElementById('kpi-students').textContent = totalStudents;
            document.getElementById('kpi-noteacher').textContent = data.filter(c => !c.teacherId).length;
        }

        function renderCourses(data) {
            const list = document.getElementById('course-list');
            if (data.length === 0) {
                list.innerHTML = '<div class="loading-row">No courses found.</div>';
                return;
            }
            list.innerHTML = data.map(c => {
                const teacher = allTeachers.find(t => t.id === c.teacherId);
                const teacherName = teacher
                    ? `${teacher.firstName} ${teacher.lastName}`
                    : (c.teacher ? `${c.teacher.firstName} ${c.teacher.lastName}` : '—');
                const studentCount = c.students?.length ?? 0;
                return `
                <div class="t-row">
                    <span class="id-mono">${c.id}</span>
                    <div class="name-cell">
                        <div class="c-icon">📚</div>
                        <span class="course-name">${c.courseName}</span>
                    </div>
                    <div class="teacher-cell">
                        <div class="s-av">${teacherName !== '—' ? teacherName.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2) : '?'}</div>
                        <span>${teacherName}</span>
                    </div>
                    <span class="count-badge">${studentCount} student${studentCount !== 1 ? 's' : ''}</span>
                    <div class="row-acts">
                        <button class="ra-btn btn-edit" onclick="openEditModal(${c.id})">✏ Edit</button>
                        <button class="ra-btn btn-del" onclick="deleteCourse(${c.id}, '${c.courseName.replace(/'/g,"\\'")}')">🗑 Delete</button>
                    </div>
                </div>`;
            }).join('');
        }

        function filterCourses() {
            const q = document.getElementById('search-input').value.toLowerCase();
            renderCourses(allCourses.filter(c => c.courseName.toLowerCase().includes(q)));
        }

        function openModal() {
            document.getElementById('modal-title').textContent = 'Add New Course';
            document.getElementById('edit-id').value = '';
            document.getElementById('f-coursename').value = '';
            document.getElementById('f-teacherid').value = '';
            document.getElementById('btn-save').textContent = 'Save Course';
            document.getElementById('modal-error').style.display = 'none';
            document.getElementById('modal-overlay').classList.add('active');
            document.getElementById('modal').classList.add('active');
        }

        function openEditModal(id) {
            const c = allCourses.find(x => x.id === id);
            if (!c) return;
            document.getElementById('modal-title').textContent = 'Edit Course';
            document.getElementById('edit-id').value = c.id;
            document.getElementById('f-coursename').value = c.courseName;
            document.getElementById('f-teacherid').value = c.teacherId;
            document.getElementById('btn-save').textContent = 'Update Course';
            document.getElementById('modal-error').style.display = 'none';
            document.getElementById('modal-overlay').classList.add('active');
            document.getElementById('modal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('modal-overlay').classList.remove('active');
            document.getElementById('modal').classList.remove('active');
        }

        async function saveCourse() {
            const id = document.getElementById('edit-id').value;
            const teacherId = parseInt(document.getElementById('f-teacherid').value);
            const body = {
                courseName: document.getElementById('f-coursename').value.trim(),
                teacherId:  isNaN(teacherId) ? 0 : teacherId
            };
            if (!body.courseName || !body.teacherId) {
                showModalError('Course name and teacher are required.');
                return;
            }
            const url    = id ? `${API}/${id}` : API;
            const method = id ? 'PUT' : 'POST';
            try {
                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                if (!res.ok) throw new Error(await res.text());
                closeModal();
                loadData();
            } catch (e) {
                showModalError('Save failed: ' + e.message);
            }
        }

        async function deleteCourse(id, name) {
            if (!confirm(`Delete course "${name}"? This cannot be undone.`)) return;
            try {
                const res = await fetch(`${API}/${id}`, { method: 'DELETE' });
                if (!res.ok) throw new Error(await res.text());
                loadData();
            } catch (e) {
                alert('Delete failed: ' + e.message);
            }
        }

        function showModalError(msg) {
            const el = document.getElementById('modal-error');
            el.textContent = msg;
            el.style.display = 'block';
        }

        loadData();
    </script>
</body>
</html>
