@{
    Layout = null;
    ViewData["Title"] = "Attendance Manager – Teachers";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/teachers.css" asp-append-version="true" />
</head>
<body>
    <aside>
        <div class="brand">
            <div class="brand-icon"><img src="~/images/dbtc-logo.png" alt="DBTC Logo" style="width:28px;height:28px;object-fit:contain;border-radius:6px;" /></div>
            <div><div class="brand-name">Attendance</div><div class="brand-sub">Manager Pro</div></div>
        </div>
        <nav>
            <a class="nav-item" href="/Account/Dashboard"><span class="nav-icon">⊞</span> Dashboard</a>
            <a class="nav-item" href="/Account/Students"><span class="nav-icon">🎓</span> Students</a>
            <a class="nav-item active" href="/Account/Teachers"><span class="nav-icon">👨‍🏫</span> Teachers</a>
            <a class="nav-item" href="/Account/Courses"><span class="nav-icon">📚</span> Courses</a>
            <a class="nav-item" href="/Account/Classes"><span class="nav-icon">🏫</span> Classes</a>
            <a class="nav-item" href="/Account/Enrollment"><span class="nav-icon">📋</span> Enrollment</a>
            <a class="nav-item" href="/Account/Attendance"><span class="nav-icon">✓</span> Attendance</a>
            <a class="nav-item" href="/Account/Reports"><span class="nav-icon">📊</span> Reports</a>
            <a class="nav-item" href="/Account/Settings"><span class="nav-icon">⚙</span> Settings</a>
        </nav>
        <div class="sidebar-footer">
            <div class="user-card">
                <div class="avatar">JG</div>
                <div><div class="user-name">James Gulfan</div><div class="user-role">Administrator</div></div>
            </div>
            <form action="/Account/Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn">↩ Logout</button>
            </form>
        </div>
    </aside>

    <main>
        <div class="page-header">
            <div>
                <div class="page-title">Teacher Management</div>
                <div class="page-sub">Manage faculty records from <code>GET /api/teachers</code></div>
            </div>
            <button class="add-btn" onclick="openModal()">+ Add New Teacher</button>
        </div>

        <!-- KPI row -->
        <div class="kpi-row">
            <div class="kpi-mini"><div class="kl">Total Teachers</div><div class="kv" id="kpi-total" style="color:var(--blue)">—</div><div class="ks">All records</div></div>
            <div class="kpi-mini"><div class="kl">With Courses</div><div class="kv" id="kpi-assigned" style="color:var(--accent)">—</div><div class="ks">Assigned to course</div></div>
            <div class="kpi-mini"><div class="kl">No Course</div><div class="kv" id="kpi-unassigned" style="color:var(--amber)">—</div><div class="ks">Not yet assigned</div></div>
        </div>

        <!-- Search -->
        <div class="controls">
            <div class="search-box"><span>🔍</span><input type="text" id="search-input" placeholder="Search by name or email…" oninput="filterTeachers()" /></div>
        </div>

        <!-- Table -->
        <div class="table-panel">
            <div class="t-head">
                <span class="th">ID</span>
                <span class="th">First Name</span>
                <span class="th">Last Name</span>
                <span class="th">Email</span>
                <span class="th">Actions</span>
            </div>
            <div id="teacher-list"><div class="loading-row">Loading…</div></div>
        </div>
    </main>

    <!-- ── Modal ── -->
    <div class="modal-overlay" id="modal-overlay" onclick="closeModal()"></div>
    <div class="modal" id="modal">
        <div class="modal-header">
            <span id="modal-title">Add New Teacher</span>
            <button class="modal-close" onclick="closeModal()">✕</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="edit-id" />
            <div class="field-row">
                <div class="field">
                    <label>First Name</label>
                    <input type="text" id="f-firstname" placeholder="e.g. Maria" />
                </div>
                <div class="field">
                    <label>Last Name</label>
                    <input type="text" id="f-lastname" placeholder="e.g. Santos" />
                </div>
            </div>
            <div class="field">
                <label>Email</label>
                <input type="email" id="f-email" placeholder="teacher@@dbtc-cebu.edu.ph" />
            </div>
            <div id="modal-error" class="modal-error" style="display:none"></div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal()">Cancel</button>
            <button class="btn-save" id="btn-save" onclick="saveTeacher()">Save Teacher</button>
        </div>
    </div>

    <script>
        const API = 'https://localhost:7152/api/teachers';
        let allTeachers = [];
        let allCourses  = [];

        async function loadData() {
            try {
                const [tRes, cRes] = await Promise.all([fetch(API), fetch('https://localhost:7152/api/courses')]);
                allTeachers = await tRes.json();
                allCourses  = cRes.ok ? await cRes.json() : [];
                renderTeachers(allTeachers);
                updateKPIs();
            } catch (e) {
                document.getElementById('teacher-list').innerHTML =
                    '<div class="loading-row error-row">Could not load teachers. Is the API running?</div>';
            }
        }

        function updateKPIs() {
            document.getElementById('kpi-total').textContent = allTeachers.length;
            const assignedIds = new Set(allCourses.map(c => c.teacherId));
            const assigned = allTeachers.filter(t => assignedIds.has(t.id)).length;
            document.getElementById('kpi-assigned').textContent = assigned;
            document.getElementById('kpi-unassigned').textContent = allTeachers.length - assigned;
        }

        function getInitials(f, l) {
            return ((f?.[0] ?? '') + (l?.[0] ?? '')).toUpperCase();
        }

        function renderTeachers(data) {
            const list = document.getElementById('teacher-list');
            if (data.length === 0) {
                list.innerHTML = '<div class="loading-row">No teachers found.</div>';
                return;
            }
            list.innerHTML = data.map(t => `
                <div class="t-row">
                    <span class="id-mono">${t.id}</span>
                    <div class="name-cell">
                        <div class="s-av">${getInitials(t.firstName, t.lastName)}</div>
                        <span>${t.firstName}</span>
                    </div>
                    <span class="cell-text">${t.lastName}</span>
                    <span class="cell-email">${t.email}</span>
                    <div class="row-acts">
                        <button class="ra-btn btn-edit" onclick="openEditModal(${t.id})">✏ Edit</button>
                        <button class="ra-btn btn-del" onclick="deleteTeacher(${t.id}, '${t.firstName} ${t.lastName}')">🗑 Delete</button>
                    </div>
                </div>`).join('');
        }

        function filterTeachers() {
            const q = document.getElementById('search-input').value.toLowerCase();
            renderTeachers(allTeachers.filter(t =>
                t.firstName.toLowerCase().includes(q) ||
                t.lastName.toLowerCase().includes(q) ||
                t.email.toLowerCase().includes(q)
            ));
        }

        function openModal() {
            document.getElementById('modal-title').textContent = 'Add New Teacher';
            document.getElementById('edit-id').value = '';
            document.getElementById('f-firstname').value = '';
            document.getElementById('f-lastname').value = '';
            document.getElementById('f-email').value = '';
            document.getElementById('btn-save').textContent = 'Save Teacher';
            document.getElementById('modal-error').style.display = 'none';
            document.getElementById('modal-overlay').classList.add('active');
            document.getElementById('modal').classList.add('active');
        }

        function openEditModal(id) {
            const t = allTeachers.find(x => x.id === id);
            if (!t) return;
            document.getElementById('modal-title').textContent = 'Edit Teacher';
            document.getElementById('edit-id').value = t.id;
            document.getElementById('f-firstname').value = t.firstName;
            document.getElementById('f-lastname').value = t.lastName;
            document.getElementById('f-email').value = t.email;
            document.getElementById('btn-save').textContent = 'Update Teacher';
            document.getElementById('modal-error').style.display = 'none';
            document.getElementById('modal-overlay').classList.add('active');
            document.getElementById('modal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('modal-overlay').classList.remove('active');
            document.getElementById('modal').classList.remove('active');
        }

        async function saveTeacher() {
            const id = document.getElementById('edit-id').value;
            const body = {
                firstName: document.getElementById('f-firstname').value.trim(),
                lastName:  document.getElementById('f-lastname').value.trim(),
                email:     document.getElementById('f-email').value.trim()
            };
            if (!body.firstName || !body.lastName || !body.email) {
                showModalError('All fields are required.');
                return;
            }
            const url    = id ? `${API}/${id}` : API;
            const method = id ? 'PUT' : 'POST';
            try {
                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                if (!res.ok) throw new Error(await res.text());
                closeModal();
                loadData();
            } catch (e) {
                showModalError('Save failed: ' + e.message);
            }
        }

        async function deleteTeacher(id, name) {
            if (!confirm(`Delete teacher "${name}"? This cannot be undone.`)) return;
            try {
                const res = await fetch(`${API}/${id}`, { method: 'DELETE' });
                if (!res.ok) throw new Error(await res.text());
                loadData();
            } catch (e) {
                alert('Delete failed: ' + e.message);
            }
        }

        function showModalError(msg) {
            const el = document.getElementById('modal-error');
            el.textContent = msg;
            el.style.display = 'block';
        }

        loadData();
    </script>
</body>
</html>
