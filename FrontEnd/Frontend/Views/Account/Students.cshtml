@{
    Layout = null;
    ViewData["Title"] = "Attendance Manager – Students";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/students.css" asp-append-version="true" />
</head>
<body>
    <aside>
        <div class="brand">
            <div class="brand-icon"><img src="~/images/dbtc-logo.png" alt="DBTC Logo" style="width:28px;height:28px;object-fit:contain;border-radius:6px;" /></div>
            <div><div class="brand-name">Attendance</div><div class="brand-sub">Manager Pro</div></div>
        </div>
        <nav>
            <a class="nav-item" href="/Account/Dashboard"><span class="nav-icon">⊞</span> Dashboard</a>
            <a class="nav-item active" href="/Account/Students"><span class="nav-icon">🎓</span> Students</a>
            <a class="nav-item" href="/Account/Teachers"><span class="nav-icon">👨‍🏫</span> Teachers</a>
            <a class="nav-item" href="/Account/Courses"><span class="nav-icon">📚</span> Courses</a>
            <a class="nav-item" href="/Account/Classes"><span class="nav-icon">🏫</span> Classes</a>
            <a class="nav-item" href="/Account/Enrollment"><span class="nav-icon">📋</span> Enrollment</a>
            <a class="nav-item" href="/Account/Attendance"><span class="nav-icon">✓</span> Attendance</a>
            <a class="nav-item" href="/Account/Reports"><span class="nav-icon">📊</span> Reports</a>
            <a class="nav-item" href="/Account/Settings"><span class="nav-icon">⚙</span> Settings</a>
        </nav>
        <div class="sidebar-footer">
            <div class="user-card">
                <div class="avatar">JG</div>
                <div><div class="user-name">James Gulfan</div><div class="user-role">Administrator</div></div>
            </div>
            <form action="/Account/Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn">↩ Logout</button>
            </form>
        </div>
    </aside>

    <main>
        <div class="page-header">
            <div>
                <div class="page-title">Student Management</div>
                <div class="page-sub">Manage student records from <code>GET /api/students</code></div>
            </div>
            <button class="add-btn" onclick="openModal()">+ Add New Student</button>
        </div>

        <!-- KPI row -->
        <div class="kpi-row">
            <div class="kpi-mini"><div class="kl">Total Students</div><div class="kv" id="kpi-total" style="color:var(--blue)">—</div><div class="ks">All records</div></div>
            <div class="kpi-mini"><div class="kl">Courses Assigned</div><div class="kv" id="kpi-courses" style="color:var(--accent)">—</div><div class="ks">Unique courses</div></div>
            <div class="kpi-mini"><div class="kl">No Course</div><div class="kv" id="kpi-nocourse" style="color:var(--amber)">—</div><div class="ks">Missing assignment</div></div>
        </div>

        <!-- Search -->
        <div class="controls">
            <div class="search-box"><span>🔍</span><input type="text" id="search-input" placeholder="Search by name or email…" oninput="filterStudents()" /></div>
        </div>

        <!-- Table -->
        <div class="table-panel">
            <div class="t-head">
                <span class="th">ID</span>
                <span class="th">First Name</span>
                <span class="th">Last Name</span>
                <span class="th">Email</span>
                <span class="th">Course</span>
                <span class="th">Actions</span>
            </div>
            <div id="student-list"><div class="loading-row">Loading…</div></div>
        </div>
    </main>

    <!-- ── Modal ── -->
    <div class="modal-overlay" id="modal-overlay" onclick="closeModal()"></div>
    <div class="modal" id="modal">
        <div class="modal-header">
            <span id="modal-title">Add New Student</span>
            <button class="modal-close" onclick="closeModal()">✕</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="edit-id" />
            <div class="field-row">
                <div class="field">
                    <label>First Name</label>
                    <input type="text" id="f-firstname" placeholder="e.g. Juan" />
                </div>
                <div class="field">
                    <label>Last Name</label>
                    <input type="text" id="f-lastname" placeholder="e.g. dela Cruz" />
                </div>
            </div>
            <div class="field">
                <label>Email</label>
                <input type="email" id="f-email" placeholder="student@@dbtc-cebu.edu.ph" />
            </div>
            <div class="field">
                <label>Course ID</label>
                <input type="number" id="f-courseid" placeholder="e.g. 1" min="1" />
                <span class="field-hint">Enter the Course ID from the Courses list</span>
            </div>
            <div id="modal-error" class="modal-error" style="display:none"></div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal()">Cancel</button>
            <button class="btn-save" id="btn-save" onclick="saveStudent()">Save Student</button>
        </div>
    </div>

    <script>
        const API = 'https://localhost:7152/api/students';
        let allStudents = [];

        async function loadStudents() {
            try {
                const res = await fetch(API);
                if (!res.ok) throw new Error('Failed to fetch');
                allStudents = await res.json();
                renderStudents(allStudents);
                updateKPIs(allStudents);
            } catch (e) {
                document.getElementById('student-list').innerHTML =
                    '<div class="loading-row error-row">Could not load students. Is the API running?</div>';
            }
        }

        function updateKPIs(data) {
            document.getElementById('kpi-total').textContent = data.length;
            const uniqueCourses = new Set(data.filter(s => s.courseId).map(s => s.courseId));
            document.getElementById('kpi-courses').textContent = uniqueCourses.size;
            document.getElementById('kpi-nocourse').textContent = data.filter(s => !s.courseId).length;
        }

        function getInitials(f, l) {
            return ((f?.[0] ?? '') + (l?.[0] ?? '')).toUpperCase();
        }

        function renderStudents(data) {
            const list = document.getElementById('student-list');
            if (data.length === 0) {
                list.innerHTML = '<div class="loading-row">No students found.</div>';
                return;
            }
            list.innerHTML = data.map(s => `
                <div class="t-row">
                    <span class="id-mono">${s.id}</span>
                    <div class="name-cell">
                        <div class="s-av">${getInitials(s.firstName, s.lastName)}</div>
                        <span>${s.firstName}</span>
                    </div>
                    <span class="cell-text">${s.lastName}</span>
                    <span class="cell-email">${s.email}</span>
                    <span class="course-chip">${s.course?.courseName ?? 'Course #' + s.courseId}</span>
                    <div class="row-acts">
                        <button class="ra-btn btn-edit" onclick="openEditModal(${s.id})">✏ Edit</button>
                        <button class="ra-btn btn-del" onclick="deleteStudent(${s.id}, '${s.firstName} ${s.lastName}')">🗑 Delete</button>
                    </div>
                </div>`).join('');
        }

        function filterStudents() {
            const q = document.getElementById('search-input').value.toLowerCase();
            renderStudents(allStudents.filter(s =>
                s.firstName.toLowerCase().includes(q) ||
                s.lastName.toLowerCase().includes(q) ||
                s.email.toLowerCase().includes(q)
            ));
        }

        function openModal() {
            document.getElementById('modal-title').textContent = 'Add New Student';
            document.getElementById('edit-id').value = '';
            document.getElementById('f-firstname').value = '';
            document.getElementById('f-lastname').value = '';
            document.getElementById('f-email').value = '';
            document.getElementById('f-courseid').value = '';
            document.getElementById('btn-save').textContent = 'Save Student';
            document.getElementById('modal-error').style.display = 'none';
            document.getElementById('modal-overlay').classList.add('active');
            document.getElementById('modal').classList.add('active');
        }

        function openEditModal(id) {
            const s = allStudents.find(x => x.id === id);
            if (!s) return;
            document.getElementById('modal-title').textContent = 'Edit Student';
            document.getElementById('edit-id').value = s.id;
            document.getElementById('f-firstname').value = s.firstName;
            document.getElementById('f-lastname').value = s.lastName;
            document.getElementById('f-email').value = s.email;
            document.getElementById('f-courseid').value = s.courseId;
            document.getElementById('btn-save').textContent = 'Update Student';
            document.getElementById('modal-error').style.display = 'none';
            document.getElementById('modal-overlay').classList.add('active');
            document.getElementById('modal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('modal-overlay').classList.remove('active');
            document.getElementById('modal').classList.remove('active');
        }

        async function saveStudent() {
            const id = document.getElementById('edit-id').value;
            const body = {
                firstName: document.getElementById('f-firstname').value.trim(),
                lastName:  document.getElementById('f-lastname').value.trim(),
                email:     document.getElementById('f-email').value.trim(),
                courseId:  parseInt(document.getElementById('f-courseid').value)
            };

            if (!body.firstName || !body.lastName || !body.email || !body.courseId) {
                showModalError('All fields are required.');
                return;
            }

            const url    = id ? `${API}/${id}` : API;
            const method = id ? 'PUT' : 'POST';

            try {
                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                if (!res.ok) throw new Error(await res.text());
                closeModal();
                loadStudents();
            } catch (e) {
                showModalError('Save failed: ' + e.message);
            }
        }

        async function deleteStudent(id, name) {
            if (!confirm(`Delete student "${name}"? This cannot be undone.`)) return;
            try {
                const res = await fetch(`${API}/${id}`, { method: 'DELETE' });
                if (!res.ok) throw new Error(await res.text());
                loadStudents();
            } catch (e) {
                alert('Delete failed: ' + e.message);
            }
        }

        function showModalError(msg) {
            const el = document.getElementById('modal-error');
            el.textContent = msg;
            el.style.display = 'block';
        }

        loadStudents();
    </script>
</body>
</html>
