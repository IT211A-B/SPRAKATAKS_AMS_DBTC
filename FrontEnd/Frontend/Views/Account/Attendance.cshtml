@{
    Layout = null;
    ViewData["Title"] = "Attendance Manager – Attendance";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #c8d9a0;
            --sidebar-bg: #5a7a3a;
            --surface: #d4e4aa;
            --card: #e4f0c0;
            --border: rgba(90,122,58,0.22);
            --accent: #3d6b20;
            --accent-light: #5c8f35;
            --text: #243318;
            --text2: #527038;
            --text3: #7a9858;
            --red: #b83228;
            --red-bg: rgba(184,50,40,0.1);
            --amber: #a86820;
            --amber-bg: rgba(168,104,32,0.1);
            --blue: #2a5f8a;
            --blue-bg: rgba(42,95,138,0.1);
            --radius: 16px;
            --sidebar: 228px
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        body {
            font-family: Outfit,sans-serif;
            background: var(--bg);
            color: var(--text);
            display: flex;
            height: 100vh;
            overflow: hidden
        }

        aside {
            width: var(--sidebar);
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            flex-shrink: 0
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 22px 18px;
            border-bottom: 1px solid rgba(255,255,255,.12)
        }

        .brand-icon {
            width: 38px;
            height: 38px;
            background: rgba(255,255,255,.15);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px
        }

        .brand-name {
            font-size: 14px;
            font-weight: 700;
            color: #fff;
            line-height: 1.2
        }

        .brand-sub {
            font-size: 10px;
            color: rgba(255,255,255,.5)
        }

        nav {
            flex: 1;
            padding: 14px 10px;
            display: flex;
            flex-direction: column;
            gap: 3px;
            overflow-y: auto
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 9px 12px;
            border-radius: 10px;
            cursor: pointer;
            color: rgba(255,255,255,.6);
            font-size: 13px;
            font-weight: 500;
            transition: all .2s;
            text-decoration: none
        }

            .nav-item:hover {
                background: rgba(255,255,255,.1);
                color: #fff
            }

            .nav-item.active {
                background: rgba(255,255,255,.2);
                color: #fff;
                font-weight: 600
            }

        .nav-icon {
            width: 18px;
            text-align: center;
            font-size: 14px
        }

        .sidebar-footer {
            padding: 14px;
            border-top: 1px solid rgba(255,255,255,.12)
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            background: rgba(255,255,255,.1);
            margin-bottom: 8px
        }

        .avatar {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: rgba(255,255,255,.22);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0
        }

        .user-name {
            font-size: 12.5px;
            font-weight: 600;
            color: #fff
        }

        .user-role {
            font-size: 10px;
            color: rgba(255,255,255,.5)
        }

        .logout-btn {
            width: 100%;
            padding: 8px;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,.15);
            background: transparent;
            color: rgba(255,255,255,.6);
            font-size: 12px;
            font-family: Outfit,sans-serif;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            transition: all .2s
        }

            .logout-btn:hover {
                background: rgba(255,255,255,.1);
                color: #fff
            }

        main {
            flex: 1;
            overflow-y: auto;
            padding: 28px;
            display: flex;
            flex-direction: column;
            gap: 20px
        }

            main::-webkit-scrollbar {
                width: 4px
            }

            main::-webkit-scrollbar-thumb {
                background: var(--surface);
                border-radius: 10px
            }

        .page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between
        }

        .page-title {
            font-size: 24px;
            font-weight: 800
        }

        .page-sub {
            font-size: 12.5px;
            color: var(--text2);
            margin-top: 3px
        }

        .add-btn {
            padding: 10px 20px;
            border-radius: 10px;
            background: var(--accent);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            transition: all .2s;
            font-family: Outfit,sans-serif
        }

            .add-btn:hover {
                background: var(--accent-light);
                transform: translateY(-1px)
            }

        .kpi-row {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 12px
        }

        .kpi-mini {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 16px 18px
        }

        .kl {
            font-size: 11px;
            font-weight: 600;
            color: var(--text2);
            text-transform: uppercase;
            letter-spacing: .06em;
            margin-bottom: 7px
        }

        .kv {
            font-size: 28px;
            font-weight: 800;
            font-family: monospace
        }

        .ks {
            font-size: 11px;
            color: var(--text3);
            margin-top: 3px
        }

        .controls {
            display: flex;
            gap: 10px
        }

        .search-box {
            flex: 1;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 10px 14px;
            display: flex;
            align-items: center;
            gap: 10px
        }

            .search-box input {
                background: transparent;
                border: none;
                outline: none;
                color: var(--text);
                font-size: 13px;
                flex: 1;
                font-family: Outfit,sans-serif
            }

                .search-box input::placeholder {
                    color: var(--text3)
                }

        .f-sel {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 10px 14px;
            color: var(--text2);
            font-size: 13px;
            font-family: Outfit,sans-serif;
            cursor: pointer;
            outline: none
        }

        .table-panel {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            overflow: hidden
        }

        .t-head, .t-row {
            display: grid;
            grid-template-columns: 60px 1.6fr 1.2fr 110px 90px 140px;
            padding: 11px 18px;
            border-bottom: 1px solid var(--border);
            align-items: center
        }

        .t-head {
            background: var(--surface)
        }

        .t-row {
            padding: 13px 18px;
            transition: background .15s
        }

            .t-row:last-child {
                border-bottom: none
            }

            .t-row:hover {
                background: var(--surface)
            }

        .th {
            font-size: 10px;
            font-weight: 700;
            color: var(--text3);
            text-transform: uppercase;
            letter-spacing: .07em
        }

        .id-mono {
            font-size: 11.5px;
            font-family: monospace;
            color: var(--text3)
        }

        .name-cell {
            display: flex;
            align-items: center;
            gap: 8px
        }

        .s-av {
            width: 30px;
            height: 30px;
            border-radius: 8px;
            background: rgba(61,107,32,.18);
            color: var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 10px;
            font-weight: 700;
            flex-shrink: 0
        }

        .cell-text {
            font-size: 13px;
            font-weight: 600;
            color: var(--text)
        }

        .class-chip {
            font-size: 11px;
            font-weight: 600;
            background: var(--blue-bg);
            color: var(--blue);
            padding: 3px 10px;
            border-radius: 6px
        }

        .date-val {
            font-size: 12px;
            color: var(--text2)
        }

        .status-pill {
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 10.5px;
            font-weight: 700
        }

        .present-pill, .enrolled-pill {
            background: rgba(61,107,32,.14);
            color: var(--accent)
        }

        .absent-pill, .dropped-pill {
            background: var(--red-bg);
            color: var(--red)
        }

        .late-pill, .pending-pill {
            background: var(--amber-bg);
            color: var(--amber)
        }

        .row-acts {
            display: flex;
            gap: 6px
        }

        .ra-btn {
            padding: 5px 12px;
            border-radius: 7px;
            border: none;
            cursor: pointer;
            font-size: 11.5px;
            font-weight: 600;
            font-family: Outfit,sans-serif;
            transition: all .15s;
            display: flex;
            align-items: center;
            gap: 4px
        }

        .btn-edit {
            background: var(--surface);
            color: var(--text2);
            border: 1px solid var(--border)
        }

            .btn-edit:hover {
                color: var(--accent);
                border-color: var(--accent)
            }

        .btn-del {
            background: var(--red-bg);
            color: var(--red);
            border: 1px solid rgba(184,50,40,.2)
        }

            .btn-del:hover {
                background: rgba(184,50,40,.18)
            }

        .loading-row {
            padding: 24px 18px;
            text-align: center;
            color: var(--text3);
            font-size: 13px
        }

        .error-row {
            color: var(--red)
        }

        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(26,58,42,.45);
            z-index: 100;
            display: none
        }

            .modal-overlay.active {
                display: block
            }

        .modal {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%,-50%) scale(.96);
            z-index: 101;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            width: 480px;
            max-width: calc(100vw - 40px);
            box-shadow: 0 20px 60px rgba(26,58,42,.25);
            display: none;
            flex-direction: column;
            opacity: 0;
            transition: all .2s
        }

            .modal.active {
                display: flex;
                opacity: 1;
                transform: translate(-50%,-50%) scale(1)
            }

        .modal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 20px;
            border-bottom: 1px solid var(--border);
            font-size: 15px;
            font-weight: 700
        }

        .modal-close {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 16px;
            color: var(--text3);
            padding: 4px;
            border-radius: 6px
        }

            .modal-close:hover {
                color: var(--red)
            }

        .modal-body {
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 14px
        }

        .modal-footer {
            padding: 16px 20px;
            border-top: 1px solid var(--border);
            display: flex;
            justify-content: flex-end;
            gap: 10px
        }

        .field {
            display: flex;
            flex-direction: column;
            gap: 5px
        }

        .field-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px
        }

        .field label {
            font-size: 12px;
            font-weight: 600;
            color: var(--text2)
        }

        .field input, .field select {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 9px;
            padding: 9px 12px;
            font-size: 13px;
            color: var(--text);
            font-family: Outfit,sans-serif;
            outline: none;
            transition: border-color .2s
        }

            .field input:focus, .field select:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(61,107,32,.1)
            }

        .field-hint {
            font-size: 11px;
            color: var(--text3)
        }

        .modal-error {
            background: var(--red-bg);
            color: var(--red);
            border: 1px solid rgba(184,50,40,.2);
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 12.5px
        }

        .btn-cancel {
            padding: 9px 20px;
            border-radius: 9px;
            border: 1px solid var(--border);
            background: transparent;
            color: var(--text2);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            font-family: Outfit,sans-serif
        }

            .btn-cancel:hover {
                background: var(--surface)
            }

        .btn-save {
            padding: 9px 20px;
            border-radius: 9px;
            border: none;
            background: var(--accent);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            font-family: Outfit,sans-serif
        }

            .btn-save:hover {
                background: var(--accent-light)
            }
    </style>
</head>
<body>
    <aside>
        <div class="brand">
            <div class="brand-icon"><img src="~/images/dbtc-logo.png" alt="DBTC Logo" style="width:28px;height:28px;object-fit:contain;border-radius:6px;" /></div>
            <div><div class="brand-name">Attendance</div><div class="brand-sub">Manager Pro</div></div>
        </div>
        <nav>
            <a class="nav-item" href="/Account/Dashboard"><span class="nav-icon">⊞</span> Dashboard</a>
            <a class="nav-item" href="/Account/Students"><span class="nav-icon">🎓</span> Students</a>
            <a class="nav-item" href="/Account/Teachers"><span class="nav-icon">👨‍🏫</span> Teachers</a>
            <a class="nav-item" href="/Account/Courses"><span class="nav-icon">📚</span> Courses</a>
            <a class="nav-item" href="/Account/Classes"><span class="nav-icon">🏫</span> Classes</a>
            <a class="nav-item" href="/Account/Enrollment"><span class="nav-icon">📋</span> Enrollment</a>
            <a class="nav-item active" href="/Account/Attendance"><span class="nav-icon">✓</span> Attendance</a>
            <a class="nav-item" href="/Account/Reports"><span class="nav-icon">📊</span> Reports</a>
            <a class="nav-item" href="/Account/Settings"><span class="nav-icon">⚙</span> Settings</a>
        </nav>
        <div class="sidebar-footer">
            <div class="user-card">
                <div class="avatar">JG</div>
                <div><div class="user-name">James Gulfan</div><div class="user-role">Administrator</div></div>
            </div>
            <form action="/Account/Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn">↩ Logout</button>
            </form>
        </div>
    </aside>

    <main>
        <div class="page-header">
            <div>
                <div class="page-title">Attendance</div>
                <div class="page-sub">Mark and manage attendance from <code>GET /api/attendances</code></div>
            </div>
            <button class="add-btn" onclick="openModal()">+ Mark Attendance</button>
        </div>

        <div class="kpi-row">
            <div class="kpi-mini"><div class="kl">Total Records</div><div class="kv" id="kpi-total" style="color:var(--blue)">—</div><div class="ks">All entries</div></div>
            <div class="kpi-mini"><div class="kl">Present</div><div class="kv" id="kpi-present" style="color:var(--accent)">—</div><div class="ks">Marked present</div></div>
            <div class="kpi-mini"><div class="kl">Absent</div><div class="kv" id="kpi-absent" style="color:var(--red)">—</div><div class="ks">Marked absent</div></div>
            <div class="kpi-mini"><div class="kl">Late</div><div class="kv" id="kpi-late" style="color:var(--amber)">—</div><div class="ks">Marked late</div></div>
        </div>

        <div class="controls">
            <div class="search-box"><span>🔍</span><input type="text" id="search-input" placeholder="Search by student name or class…" oninput="filterAttendance()" /></div>
            <select class="f-sel" id="filter-status" onchange="filterAttendance()">
                <option value="">All Status</option>
                <option>Present</option>
                <option>Absent</option>
                <option>Late</option>
            </select>
            <input type="date" class="f-sel" id="filter-date" onchange="filterAttendance()" />
        </div>

        <div class="table-panel">
            <div class="t-head">
                <span class="th">ID</span>
                <span class="th">Student</span>
                <span class="th">Class</span>
                <span class="th">Date</span>
                <span class="th">Status</span>
                <span class="th">Actions</span>
            </div>
            <div id="attendance-list"><div class="loading-row">Loading…</div></div>
        </div>
    </main>

    <div class="modal-overlay" id="modal-overlay" onclick="closeModal()"></div>
    <div class="modal" id="modal">
        <div class="modal-header">
            <span id="modal-title">Mark Attendance</span>
            <button class="modal-close" onclick="closeModal()">✕</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="edit-id" />
            <div class="field">
                <label>Student</label>
                <select id="f-studentid"><option value="">— Select a student —</option></select>
                <span class="field-hint">Loaded from <code>/api/students</code></span>
            </div>
            <div class="field">
                <label>Class</label>
                <select id="f-classid"><option value="">— Select a class —</option></select>
                <span class="field-hint">Loaded from <code>/api/classes</code></span>
            </div>
            <div class="field-row">
                <div class="field">
                    <label>Date</label>
                    <input type="date" id="f-date" />
                </div>
                <div class="field">
                    <label>Status</label>
                    <select id="f-status">
                        <option value="Present">Present</option>
                        <option value="Absent">Absent</option>
                        <option value="Late">Late</option>
                    </select>
                </div>
            </div>
            <div id="modal-error" class="modal-error" style="display:none"></div>
        </div>
        <div class="modal-footer">
            <button class="btn-cancel" onclick="closeModal()">Cancel</button>
            <button class="btn-save" id="btn-save" onclick="saveAttendance()">Save</button>
        </div>
    </div>

    <script>
        const API = 'https://localhost:7152/api/attendances';
        let allAttendance = [], allStudents = [], allClasses = [];

        async function loadData() {
            try {
                const [aRes, sRes, cRes] = await Promise.all([
                    fetch(API), fetch('https://localhost:7152/api/students'), fetch('https://localhost:7152/api/classes')
                ]);
                allAttendance = await aRes.json();
                allStudents   = sRes.ok ? await sRes.json() : [];
                allClasses    = cRes.ok ? await cRes.json() : [];
                populateSelects();
                renderAttendance(allAttendance);
                updateKPIs(allAttendance);
                // Default date filter to today
                document.getElementById('filter-date').value = new Date().toISOString().split('T')[0];
            } catch (e) {
                document.getElementById('attendance-list').innerHTML =
                    '<div class="loading-row error-row">Could not load attendance. Is the API running?</div>';
            }
        }

        function populateSelects() {
            document.getElementById('f-studentid').innerHTML =
                '<option value="">— Select a student —</option>' +
                allStudents.map(s => `<option value="${s.id}">${s.firstName} ${s.lastName}</option>`).join('');
            document.getElementById('f-classid').innerHTML =
                '<option value="">— Select a class —</option>' +
                allClasses.map(c => `<option value="${c.id}">${c.section} — ${c.yearLevel}</option>`).join('');
        }

        function updateKPIs(data) {
            document.getElementById('kpi-total').textContent   = data.length;
            document.getElementById('kpi-present').textContent = data.filter(a => a.status === 'Present').length;
            document.getElementById('kpi-absent').textContent  = data.filter(a => a.status === 'Absent').length;
            document.getElementById('kpi-late').textContent    = data.filter(a => a.status === 'Late').length;
        }

        function statusPill(s) {
            if (s === 'Present') return 'present-pill';
            if (s === 'Absent')  return 'absent-pill';
            return 'late-pill';
        }

        function renderAttendance(data) {
            const list = document.getElementById('attendance-list');
            if (!data.length) { list.innerHTML = '<div class="loading-row">No attendance records found.</div>'; return; }
            list.innerHTML = data.map(a => {
                const student  = a.student ?? allStudents.find(s => s.id === a.studentId);
                const cls      = a.class   ?? allClasses.find(c => c.id === a.classId);
                const sName    = student ? `${student.firstName} ${student.lastName}` : 'Student #' + a.studentId;
                const cName    = cls     ? `${cls.section} — ${cls.yearLevel}`        : 'Class #'   + a.classId;
                const date     = a.date  ? new Date(a.date).toLocaleDateString('en-PH') : '—';
                const initials = student ? (student.firstName[0] + student.lastName[0]).toUpperCase() : '?';
                return `
                <div class="t-row">
                    <span class="id-mono">${a.id}</span>
                    <div class="name-cell">
                        <div class="s-av">${initials}</div>
                        <span class="cell-text">${sName}</span>
                    </div>
                    <span class="class-chip">${cName}</span>
                    <span class="date-val">${date}</span>
                    <span class="status-pill ${statusPill(a.status)}">${a.status}</span>
                    <div class="row-acts">
                        <button class="ra-btn btn-edit" onclick="openEditModal(${a.id})">✏ Edit</button>
                        <button class="ra-btn btn-del" onclick="deleteAttendance(${a.id})">🗑 Delete</button>
                    </div>
                </div>`;
            }).join('');
        }

        function filterAttendance() {
            const q    = document.getElementById('search-input').value.toLowerCase();
            const st   = document.getElementById('filter-status').value;
            const date = document.getElementById('filter-date').value;
            renderAttendance(allAttendance.filter(a => {
                const s  = a.student ?? allStudents.find(x => x.id === a.studentId);
                const c  = a.class   ?? allClasses.find(x => x.id === a.classId);
                const nm = s ? `${s.firstName} ${s.lastName}`.toLowerCase() : '';
                const cl = c ? `${c.section} ${c.yearLevel}`.toLowerCase()  : '';
                const dt = a.date ? a.date.split('T')[0] : '';
                return (nm.includes(q) || cl.includes(q)) &&
                       (!st   || a.status === st) &&
                       (!date || dt === date);
            }));
        }

        function openModal() {
            document.getElementById('modal-title').textContent = 'Mark Attendance';
            document.getElementById('edit-id').value = '';
            document.getElementById('f-studentid').value = '';
            document.getElementById('f-classid').value = '';
            document.getElementById('f-date').value = new Date().toISOString().split('T')[0];
            document.getElementById('f-status').value = 'Present';
            document.getElementById('btn-save').textContent = 'Save';
            document.getElementById('modal-error').style.display = 'none';
            document.getElementById('modal-overlay').classList.add('active');
            document.getElementById('modal').classList.add('active');
        }

        function openEditModal(id) {
            const a = allAttendance.find(x => x.id === id); if (!a) return;
            document.getElementById('modal-title').textContent = 'Edit Attendance';
            document.getElementById('edit-id').value = a.id;
            document.getElementById('f-studentid').value = a.studentId;
            document.getElementById('f-classid').value = a.classId;
            document.getElementById('f-date').value = a.date ? a.date.split('T')[0] : '';
            document.getElementById('f-status').value = a.status;
            document.getElementById('btn-save').textContent = 'Update';
            document.getElementById('modal-error').style.display = 'none';
            document.getElementById('modal-overlay').classList.add('active');
            document.getElementById('modal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('modal-overlay').classList.remove('active');
            document.getElementById('modal').classList.remove('active');
        }

        async function saveAttendance() {
            const id = document.getElementById('edit-id').value;
            const body = {
                studentId: parseInt(document.getElementById('f-studentid').value),
                classId:   parseInt(document.getElementById('f-classid').value),
                date:      document.getElementById('f-date').value,
                status:    document.getElementById('f-status').value
            };
            if (!body.studentId || !body.classId || !body.date) {
                showModalError('Student, Class, and Date are required.'); return;
            }
            try {
                const res = await fetch(id ? `${API}/${id}` : API, {
                    method: id ? 'PUT' : 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                if (!res.ok) throw new Error(await res.text());
                closeModal(); loadData();
            } catch (e) { showModalError('Save failed: ' + e.message); }
        }

        async function deleteAttendance(id) {
            if (!confirm(`Delete attendance record #${id}? This cannot be undone.`)) return;
            try {
                const res = await fetch(`${API}/${id}`, { method: 'DELETE' });
                if (!res.ok) throw new Error(await res.text());
                loadData();
            } catch (e) { alert('Delete failed: ' + e.message); }
        }

        function showModalError(msg) {
            const el = document.getElementById('modal-error');
            el.textContent = msg; el.style.display = 'block';
        }

        loadData();
    </script>
</body>
</html>
