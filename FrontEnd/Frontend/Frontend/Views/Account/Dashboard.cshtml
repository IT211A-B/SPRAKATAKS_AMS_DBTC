@{
    Layout = null;
    ViewData["Title"] = "Attendance Manager – Dashboard";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>
<body>

    <!-- ── Sidebar ─────────────────────────────────────────────────── -->
    <aside>
        <div class="brand">
            <div class="brand-icon">
                <img src="~/images/dbtc-logo.png" alt="DBTC Logo" style="width:28px;height:28px;object-fit:contain;border-radius:6px;" />
            </div>
            <div>
                <div class="brand-name">Attendance</div>
                <div class="brand-sub">Manager Pro</div>
            </div>
        </div>

        <nav>
            <a class="nav-item active" href="/Account/Dashboard"><span class="nav-icon">⊞</span> Dashboard</a>
            <a class="nav-item" href="/Account/Students"><span class="nav-icon">🎓</span> Students</a>
            <a class="nav-item" href="/Account/Teachers"><span class="nav-icon">👨‍🏫</span> Teachers</a>
            <a class="nav-item" href="/Account/Courses"><span class="nav-icon">📚</span> Courses</a>
            <a class="nav-item" href="/Account/Classes"><span class="nav-icon">🏫</span> Classes</a>
            <a class="nav-item" href="/Account/Enrollment"><span class="nav-icon">📋</span> Enrollment</a>
            <a class="nav-item" href="/Account/Attendance"><span class="nav-icon">✓</span> Attendance</a>
            <a class="nav-item" href="/Account/Reports"><span class="nav-icon">📊</span> Reports</a>
            <a class="nav-item" href="/Account/Settings"><span class="nav-icon">⚙</span> Settings</a>
        </nav>

        <div class="sidebar-footer">
            <div class="user-card">
                <div class="avatar">JG</div>
                <div>
                    <div class="user-name">James Gulfan</div>
                    <div class="user-role">Administrator</div>
                </div>
            </div>
            <form action="/Account/Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn">↩ Logout</button>
            </form>
        </div>
    </aside>

    <!-- ── Main ────────────────────────────────────────────────────── -->
    <main>

        <div class="page-header">
            <div>
                <div class="page-title">Dashboard</div>
                <div class="page-date">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</div>
            </div>
            <span class="live-badge"><span class="live-dot"></span> Live</span>
        </div>

        <div class="stats-grid">
            <div class="stat-card" style="--cc:var(--blue)">
                <div class="stat-icon">👥</div>
                <div class="stat-label">Total Students</div>
                <div class="stat-value">247</div>
                <div class="stat-sub">+5 this month</div>
            </div>
            <div class="stat-card" style="--cc:var(--accent)">
                <div class="stat-icon">✅</div>
                <div class="stat-label">Present Today</div>
                <div class="stat-value">218</div>
                <div class="stat-sub">88.3% rate</div>
            </div>
            <div class="stat-card" style="--cc:var(--red)">
                <div class="stat-icon">❌</div>
                <div class="stat-label">Absent Today</div>
                <div class="stat-value">29</div>
                <div class="stat-sub">11.7% rate</div>
            </div>
            <div class="stat-card" style="--cc:var(--amber)">
                <div class="stat-icon">🏖</div>
                <div class="stat-label">On Leave</div>
                <div class="stat-value">12</div>
                <div class="stat-sub">4 pending</div>
            </div>
        </div>

        <div class="panel">
            <div class="panel-header">
                <span class="panel-title">Recent Check-ins</span>
                <span class="panel-label">Today</span>
            </div>
            <div class="checkin-item">
                <div class="ci-avatar">SJ</div>
                <div><div class="ci-name">Sarah Johnson</div><div class="ci-time">08:45 AM</div></div>
                <span class="ci-status s-ontime">On Time</span>
            </div>
            <div class="checkin-item">
                <div class="ci-avatar">MC</div>
                <div><div class="ci-name">Mike Chen</div><div class="ci-time">08:52 AM</div></div>
                <span class="ci-status s-ontime">On Time</span>
            </div>
            <div class="checkin-item">
                <div class="ci-avatar">EW</div>
                <div><div class="ci-name">Emma Wilson</div><div class="ci-time">09:03 AM</div></div>
                <span class="ci-status s-late">Late</span>
            </div>
            <div class="checkin-item">
                <div class="ci-avatar">DB</div>
                <div><div class="ci-name">David Brown</div><div class="ci-time">09:15 AM</div></div>
                <span class="ci-status s-ontime">On Time</span>
            </div>
            <div class="checkin-item">
                <div class="ci-avatar">AT</div>
                <div><div class="ci-name">Alex Thompson</div><div class="ci-time">08:38 AM</div></div>
                <span class="ci-status s-ontime">On Time</span>
            </div>
        </div>

    </main>

</body>
</html>
