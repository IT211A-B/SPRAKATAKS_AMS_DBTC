@{
    Layout = null;
    ViewData["Title"] = "Attendance Manager – Reports";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/reports.css" asp-append-version="true" />
</head>
<body>

    <!-- ── Sidebar ─────────────────────────────────────────────────── -->
    <aside>
        <div class="brand">
            <div class="brand-icon">
                <img src="~/images/dbtc-logo.png" alt="DBTC Logo" style="width:28px;height:28px;object-fit:contain;border-radius:6px;" />
            </div>
            <div>
                <div class="brand-name">Attendance</div>
                <div class="brand-sub">Manager Pro</div>
            </div>
        </div>

        <nav>
            <a class="nav-item" href="/Account/Dashboard"><span class="nav-icon">⊞</span> Dashboard</a>
            <a class="nav-item" href="/Account/Students"><span class="nav-icon">🎓</span> Students</a>
            <a class="nav-item" href="/Account/Teachers"><span class="nav-icon">👨‍🏫</span> Teachers</a>
            <a class="nav-item" href="/Account/Courses"><span class="nav-icon">📚</span> Courses</a>
            <a class="nav-item" href="/Account/Classes"><span class="nav-icon">🏫</span> Classes</a>
            <a class="nav-item" href="/Account/Enrollment"><span class="nav-icon">📋</span> Enrollment</a>
            <a class="nav-item" href="/Account/Attendance"><span class="nav-icon">✓</span> Attendance</a>
            <a class="nav-item active" href="/Account/Reports"><span class="nav-icon">📊</span> Reports</a>
            <a class="nav-item" href="/Account/Settings"><span class="nav-icon">⚙</span> Settings</a>
        </nav>

        <div class="sidebar-footer">
            <div class="user-card">
                <div class="avatar">JG</div>
                <div>
                    <div class="user-name">James Gulfan</div>
                    <div class="user-role">Administrator</div>
                </div>
            </div>
            <form action="/Account/Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn">↩ Logout</button>
            </form>
        </div>
    </aside>

    <!-- ── Main ────────────────────────────────────────────────────── -->
    <main>

        <!-- Page header -->
        <div>
            <div class="page-title">Attendance Reports</div>
            <div class="page-sub">Detailed attendance analytics and insights</div>
        </div>

        <!-- Export + filter bar -->
        <div class="top-bar">
            <button class="exp-btn btn-pdf">📄 Export PDF</button>
            <button class="exp-btn btn-xl">📊 Export Excel</button>
            <div class="spacer"></div>
            <select class="f-sel">
                <option>March 2026</option>
                <option>February 2026</option>
                <option>January 2026</option>
            </select>
            <select class="f-sel">
                <option>All Classes</option>
                <option>10A</option>
                <option>10B</option>
                <option>11A</option>
            </select>
        </div>

        <!-- KPI cards -->
        <div class="kpi-grid">
            <div class="kpi" style="--kc:var(--accent)">
                <div class="kpi-label">Average Attendance</div>
                <div class="kpi-value">88.3%</div>
                <div class="kpi-sub">+2.5% from last month</div>
            </div>
            <div class="kpi" style="--kc:var(--blue)">
                <div class="kpi-label">Best Attendance Day</div>
                <div class="kpi-value">Jan 17</div>
                <div class="kpi-sub">240/247 present (97.2%)</div>
            </div>
            <div class="kpi" style="--kc:var(--amber)">
                <div class="kpi-label">Worst Attendance Day</div>
                <div class="kpi-value">Jan 19</div>
                <div class="kpi-sub">218/247 present (88.3%)</div>
            </div>
            <div class="kpi" style="--kc:var(--text2)">
                <div class="kpi-label">Total Working Days</div>
                <div class="kpi-value">21</div>
                <div class="kpi-sub">Working days in Feb</div>
            </div>
        </div>

        <!-- Two-column panels -->
        <div class="row-2">

            <!-- Daily Attendance Records -->
            <div class="panel">
                <div class="ph">
                    <span class="ph-title">Daily Attendance Records</span>
                </div>
                <div class="dth">
                    <span class="th">Date</span>
                    <span class="th">Present</span>
                    <span class="th">Absent</span>
                    <span class="th">Late</span>
                    <span class="th">Total</span>
                    <span class="th">%</span>
                </div>
                <div class="dr"><span class="td">Jan 19</span><span class="td">218</span><span class="td">29</span><span class="td">15</span><span class="td">247</span><span class="td warn">88.3%</span></div>
                <div class="dr"><span class="td">Jan 18</span><span class="td">232</span><span class="td">15</span><span class="td">8</span><span class="td">247</span><span class="td hi">93.9%</span></div>
                <div class="dr"><span class="td">Jan 17</span><span class="td">240</span><span class="td">7</span><span class="td">5</span><span class="td">247</span><span class="td hi">97.2%</span></div>
                <div class="dr"><span class="td">Jan 16</span><span class="td">228</span><span class="td">19</span><span class="td">13</span><span class="td">247</span><span class="td hi">92.3%</span></div>
                <div class="dr"><span class="td">Jan 15</span><span class="td">221</span><span class="td">26</span><span class="td">11</span><span class="td">247</span><span class="td warn">89.5%</span></div>
            </div>

            <!-- Student-wise Attendance -->
            <div class="panel">
                <div class="ph">
                    <span class="ph-title">Student-wise Attendance</span>
                </div>
                <div class="swh">
                    <span class="th">Roll</span>
                    <span class="th">Name</span>
                    <span class="th">P</span>
                    <span class="th">A</span>
                    <span class="th">L</span>
                    <span class="th">%</span>
                    <span class="th">Status</span>
                </div>
                <div class="swr">
                    <span class="td" style="font-size:10.5px">CS-001</span>
                    <div class="sw-name"><div class="sw-av">AT</div>Alex T.</div>
                    <span class="sw-num">18</span>
                    <span class="sw-num" style="color:var(--red)">2</span>
                    <span class="sw-num" style="color:var(--amber)">1</span>
                    <div class="pct-wrap"><div class="pct-val">90%</div><div class="pct-bar"><div class="pct-fill" style="width:90%"></div></div></div>
                    <span class="chip exc">Excellent</span>
                </div>
                <div class="swr">
                    <span class="td" style="font-size:10.5px">CS-002</span>
                    <div class="sw-name"><div class="sw-av">SJ</div>Sarah J.</div>
                    <span class="sw-num">20</span>
                    <span class="sw-num" style="color:var(--red)">1</span>
                    <span class="sw-num" style="color:var(--amber)">0</span>
                    <div class="pct-wrap"><div class="pct-val">95%</div><div class="pct-bar"><div class="pct-fill" style="width:95%"></div></div></div>
                    <span class="chip exc">Excellent</span>
                </div>
                <div class="swr">
                    <span class="td" style="font-size:10.5px">CS-003</span>
                    <div class="sw-name"><div class="sw-av">MC</div>Mike C.</div>
                    <span class="sw-num">17</span>
                    <span class="sw-num" style="color:var(--red)">3</span>
                    <span class="sw-num" style="color:var(--amber)">2</span>
                    <div class="pct-wrap"><div class="pct-val" style="color:var(--blue)">89%</div><div class="pct-bar"><div class="pct-fill" style="width:89%;background:var(--blue)"></div></div></div>
                    <span class="chip good">Good</span>
                </div>
                <div class="swr">
                    <span class="td" style="font-size:10.5px">CS-004</span>
                    <div class="sw-name"><div class="sw-av">EW</div>Emma W.</div>
                    <span class="sw-num">19</span>
                    <span class="sw-num" style="color:var(--red)">2</span>
                    <span class="sw-num" style="color:var(--amber)">0</span>
                    <div class="pct-wrap"><div class="pct-val">90%</div><div class="pct-bar"><div class="pct-fill" style="width:90%"></div></div></div>
                    <span class="chip exc">Excellent</span>
                </div>
            </div>

        </div>

    </main>

</body>
</html>
